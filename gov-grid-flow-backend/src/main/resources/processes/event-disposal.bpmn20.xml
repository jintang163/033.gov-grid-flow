<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://www.gov.com/grid/workflow">

    <process id="eventDisposal" name="事件处置流程" isExecutable="true">

        <startEvent id="startEvent" name="事件上报">
            <outgoing>startToGridLeaderReview</outgoing>
        </startEvent>

        <sequenceFlow id="startToGridLeaderReview" sourceRef="startEvent" targetRef="gridLeaderReviewTask"/>

        <userTask id="gridLeaderReviewTask" name="网格长审核"
                  flowable:candidateGroups="grid_leader">
            <extensionElements>
                <flowable:taskListener event="create" class="com.gov.grid.workflow.listener.TaskCreateListener"/>
            </extensionElements>
            <incoming>startToGridLeaderReview</incoming>
            <incoming>dispatchToGridLeaderReview</incoming>
            <incoming>handleToGridLeaderReview</incoming>
            <incoming>verifyToGridLeaderReview</incoming>
            <outgoing>gridLeaderReviewToDispatch</outgoing>
        </userTask>

        <sequenceFlow id="gridLeaderReviewToDispatch" sourceRef="gridLeaderReviewTask" targetRef="dispatchTask">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${approved == true}]]>
            </conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="gridLeaderReviewReject" sourceRef="gridLeaderReviewTask" targetRef="startEvent">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${approved == false}]]>
            </conditionExpression>
        </sequenceFlow>

        <userTask id="dispatchTask" name="分派处置部门"
                  flowable:candidateGroups="admin,grid_leader">
            <extensionElements>
                <flowable:taskListener event="create" class="com.gov.grid.workflow.listener.TaskCreateListener"/>
            </extensionElements>
            <incoming>gridLeaderReviewToDispatch</incoming>
            <outgoing>dispatchToHandle</outgoing>
        </userTask>

        <sequenceFlow id="dispatchToHandle" sourceRef="dispatchTask" targetRef="handleTask"/>

        <sequenceFlow id="dispatchToGridLeaderReview" sourceRef="dispatchTask" targetRef="gridLeaderReviewTask">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${reject == true}]]>
            </conditionExpression>
        </sequenceFlow>

        <userTask id="handleTask" name="处置反馈"
                  flowable:candidateGroups="handler">
            <extensionElements>
                <flowable:taskListener event="create" class="com.gov.grid.workflow.listener.TaskCreateListener"/>
            </extensionElements>
            <incoming>dispatchToHandle</incoming>
            <outgoing>handleToVerify</outgoing>
        </userTask>

        <sequenceFlow id="handleToVerify" sourceRef="handleTask" targetRef="verifyTask">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${handleCompleted == true}]]>
            </conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="handleToGridLeaderReview" sourceRef="handleTask" targetRef="gridLeaderReviewTask">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${reject == true}]]>
            </conditionExpression>
        </sequenceFlow>

        <userTask id="verifyTask" name="网格员核查"
                  flowable:candidateGroups="worker">
            <extensionElements>
                <flowable:taskListener event="create" class="com.gov.grid.workflow.listener.TaskCreateListener"/>
            </extensionElements>
            <incoming>handleToVerify</incoming>
            <outgoing>verifyToEnd</outgoing>
        </userTask>

        <sequenceFlow id="verifyToEnd" sourceRef="verifyTask" targetRef="endEvent">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${verifyPassed == true}]]>
            </conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="verifyToGridLeaderReview" sourceRef="verifyTask" targetRef="gridLeaderReviewTask">
            <conditionExpression xsi:type="tFormalExpression">
                <![CDATA[${reject == true || verifyPassed == false}]]>
            </conditionExpression>
        </sequenceFlow>

        <endEvent id="endEvent" name="流程结束">
            <incoming>verifyToEnd</incoming>
            <incoming>gridLeaderReviewReject</incoming>
        </endEvent>

    </process>

    <bpmndi:BPMNDiagram id="BPMNDiagram_eventDisposal">
        <bpmndi:BPMNPlane bpmnElement="eventDisposal" id="BPMNPlane_eventDisposal">
            <bpmndi:BPMNShape bpmnElement="startEvent" id="BPMNShape_startEvent">
                <omgdc:Bounds height="30.0" width="30.0" x="100.0" y="163.0"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="gridLeaderReviewTask" id="BPMNShape_gridLeaderReviewTask">
                <omgdc:Bounds height="80.0" width="100.0" x="200.0" y="138.0"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="dispatchTask" id="BPMNShape_dispatchTask">
                <omgdc:Bounds height="80.0" width="100.0" x="360.0" y="138.0"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="handleTask" id="BPMNShape_handleTask">
                <omgdc:Bounds height="80.0" width="100.0" x="520.0" y="138.0"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="verifyTask" id="BPMNShape_verifyTask">
                <omgdc:Bounds height="80.0" width="100.0" x="680.0" y="138.0"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape bpmnElement="endEvent" id="BPMNShape_endEvent">
                <omgdc:Bounds height="30.0" width="30.0" x="840.0" y="163.0"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNEdge bpmnElement="startToGridLeaderReview" id="BPMNEdge_startToGridLeaderReview">
                <omgdi:waypoint x="130.0" y="178.0"/>
                <omgdi:waypoint x="200.0" y="178.0"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="gridLeaderReviewToDispatch" id="BPMNEdge_gridLeaderReviewToDispatch">
                <omgdi:waypoint x="300.0" y="178.0"/>
                <omgdi:waypoint x="360.0" y="178.0"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="dispatchToHandle" id="BPMNEdge_dispatchToHandle">
                <omgdi:waypoint x="460.0" y="178.0"/>
                <omgdi:waypoint x="520.0" y="178.0"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="handleToVerify" id="BPMNEdge_handleToVerify">
                <omgdi:waypoint x="620.0" y="178.0"/>
                <omgdi:waypoint x="680.0" y="178.0"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge bpmnElement="verifyToEnd" id="BPMNEdge_verifyToEnd">
                <omgdi:waypoint x="780.0" y="178.0"/>
                <omgdi:waypoint x="840.0" y="178.0"/>
            </bpmndi:BPMNEdge>
        </bpmndi:BPMNPlane>
    </bpmndi:BPMNDiagram>

</definitions>
